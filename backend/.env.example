NODE_ENV=development
PORT=8000

# MongoDB connection string (Atlas recommended for Render deployment)
# Example: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/jobboard?retryWrites=true&w=majority
MONGO_URI=

# Frontend origin allowed by CORS (no trailing slash)
# Example: https://your-frontend.vercel.app
FRONTEND_URL=

# JWT signing secret (long random string)
SECRET_KEY=

# Cloudinary credentials
CLOUD_NAME=
API_KEY=
API_SECRET=
